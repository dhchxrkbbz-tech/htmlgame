{
  "name": "htmlgame",
  "version": "1.0.0",
  "description": "Phaser MMO-style action RPG scaffold with Node.js, Socket.IO and MongoDB-ready backend.",
  "private": true,
  "main": "server/index.js",
  "scripts": {
    "assets:generate": "D:/asztal/otthoni/htmlgame/.venv/Scripts/python.exe tools/generate_assets.py",
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "playtest": "concurrently \"npm run server:dev\" \"npm run client:dev\" \"npm run updates:dev\"",
    "client:dev": "vite",
    "server:dev": "nodemon server/index.js",
    "updates:dev": "node launcher/update-server.cjs",
    "build": "vite build",
    "dist:launcher": "npm run build ; electron-builder",
    "preview": "vite preview",
    "start": "node server/index.js",
    "launcher": "electron launcher/main.cjs",
    "test": "vitest run",
    "test:e2e": "npm run build && playwright test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "electron-updater": "^6.8.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.18.0",
    "phaser": "^3.90.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.2.1",
    "electron": "^36.0.0",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.10",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.htmlgame.prototype",
    "productName": "HTMLGame",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "launcher/**/*",
      "server/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "generic",
        "url": "http://localhost:3005/updates"
      }
    ],
    "win": {
      "target": "nsis"
    }
  }
}
